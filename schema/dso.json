{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Docker Secret Operator (DSO) Configuration",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["aws", "azure", "vault", "huawei", "file", "env"],
      "description": "The secret backend provider to use."
    },
    "region": {
      "type": "string",
      "description": "Provider region if applicable (e.g. us-east-1)."
    },
    "config": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Provider-specific configuration parameters."
    },
    "agent": {
      "type": "object",
      "properties": {
        "cache": { "type": "boolean" },
        "refresh_interval": { "type": "string" },
        "auto_sync": { "type": "boolean" },
        "restart_strategy": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "grace_period": { "type": "string" }
          }
        },
        "watch": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["polling", "event", "hybrid"] },
            "polling_interval": { "type": "string" }
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auth_token": { "type": "string" }
          }
        },
        "rotation": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["rolling", "restart", "none"] },
            "health_check_timeout": { "type": "string" },
            "max_parallel": { "type": "integer" }
          }
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "inject", "mappings"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name or ID of the secret in the provider"
          },
          "inject": {
            "type": "string",
            "enum": ["env", "file", "socket"],
            "description": "How to inject the secret into containers"
          },
          "path": {
            "type": "string",
            "description": "Target mount path if inject strategy is file"
          },
          "rotation": {
            "type": "boolean",
            "description": "Whether to auto-refresh this secret"
          },
          "reload_strategy": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["signal", "restart", "none"] }
            }
          },
          "mappings": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Map JSON keys from the cloud secret to local environment variable names"
          }
        }
      }
    }
  },
  "required": ["provider", "secrets"]
}
